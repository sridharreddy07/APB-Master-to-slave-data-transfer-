`timescale 1ns/1ps
module apb_master_tb;

logic clk;
logic rst;

logic PSEL;
logic PENABLE;
logic PWRITE;
logic [7:0] PADDR;
logic [7:0] PWDATA;
logic [7:0] PRDATA;
logic PREADY;

logic [7:0] slave_mem;

// DUT
apb_master dut(
    .clk(clk),
    .rst(rst),
    .PSEL(PSEL),
    .PENABLE(PENABLE),
    .PWRITE(PWRITE),
    .PADDR(PADDR),
    .PWDATA(PWDATA),
    .PRDATA(PRDATA),
    .PREADY(PREADY)
);

// Clock generation
initial clk = 0;
always #10 clk = ~clk; // 50 MHz clock

assign PREADY = 1'b1; // slave always ready
assign PRDATA = (PSEL && PENABLE && !PWRITE) ? slave_mem : 8'hZZ; // drive data during read

// Simple slave write logic
always_ff @(posedge clk or posedge rst)
begin
    if (rst)
        slave_mem <= 8'h00;
    else if (PSEL && PENABLE && PWRITE)
        slave_mem <= PWDATA;
end

// Test sequence
initial begin
    rst = 1;
    #50 rst = 0;

    #500 $finish;
end

endmodule
